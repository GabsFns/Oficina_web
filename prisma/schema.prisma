// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Client {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  trucks    Truck[]
  createdAt DateTime @default(now())
}

model Truck {
  id        String   @id @default(uuid())
  plate     String   @unique
  model     String
  year      Int
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
}